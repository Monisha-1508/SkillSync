# Copy this file to .env and fill in real values before switching out of demo mode.
# Nothing in this file is a real secret - it is safe to commit this template.

# ── LLM provider switch ──────────────────────────────────────────────
# "simulated"   -> zero-cost, offline, deterministic agent brains (default, no key needed)
# "openai"      -> live calls via the OpenAI API
# "azure_openai"-> live calls via Azure OpenAI (Capgemini's preferred stack)
LLM_PROVIDER=simulated

# Used only when LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Used only when LLM_PROVIDER=azure_openai
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-05-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small

# ── App / data ───────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/skillsync.db
SECRET_KEY=dev-only-change-before-any-real-deployment
ENVIRONMENT=development

# Comma-separated origins the browser is allowed to call this API from.
# The Next.js dev server runs on 3000 by default - add your deployed
# frontend's origin here too once there is one.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Observability ────────────────────────────────────────────────────
# "console" prints OTel spans to the terminal; point OTEL_EXPORTER_OTLP_ENDPOINT
# at a collector (e.g. a local LangSmith/Phoenix endpoint) to ship spans out.
OTEL_TRACES_EXPORTER=console
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=skillsync-ai
